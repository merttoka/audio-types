float LETTER_INTERVAL = 0.5;

void setup() {
  size(512, 512);

  // initialize XYscope with default/custom sound out
  xy = new XYscope(this, "VoiceMeeter Input (VB-Audio VoiceMeeter VAIO)");

  // initialize Geomerative
  RG.init(this);
  
  moog = new MoogFilter( 15000, 0.5 );
  moog.setChannelCount(2);
  
  String text = "[The] Philosophy is written in [universe] which stands continously open to our gaze, but it cannot be understood unless one first the language and recognizes the characters in which it is written." 
    + "It is written in the language of mathematics, and its characters are triangles, circles, and other geometric figures. Without knowledge of this medium, it is impossible to understand a single word of it; without this knowledge, one is wandering about a dark labryinth.";
  //String text = "Lorem ipsum dolor sit amet, consectetur adipiscing elit. " +
  //  "Curabitur convallis sapien eu odio fringilla, egestas elementum nibh auctor.";  
  
  xy.ease(true);
  
  xy.outXY.pauseNotes();
  
  String[] words = text.split(" ");
  float totalTime = 0;
  for (int i = 0; i < words.length; i++) {
    String word = words[i];
    float wordTime = word.length()*LETTER_INTERVAL;
    xy.outXY.playNote(totalTime, wordTime, new WordInstrument(word, wordTime));
    
    //if(word.charAt(word.length()-1) == '.')
    //  totalTime += wordTime + 2;
    //else if(word.charAt(word.length()-1) == ';')
    //  totalTime += wordTime + 1;
    //else if(word.charAt(word.length()-1) == ',')
    //  totalTime += wordTime + 0.7;
    //else
      totalTime += wordTime + 2;
  }
  
  xy.outXY.resumeNotes();
}

void draw() {
  background(0);
  
  // draw XY
  xy.drawXY();
}
